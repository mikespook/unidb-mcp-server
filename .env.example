# Development mode (optional, default: false)
# Set to "true" to enable development mode with default JWT secret
DEV_MODE=false

# JWT secret key (required for production, optional for development)
# In development mode (DEV_MODE=true), this defaults to "your-secure-secret-key-here"
JWT_SECRET=your-secure-secret-key-here

# Server listen address (optional, default: localhost:9093)
ADDR=localhost:9093

# SQLite database path (optional, default: /app/data/config.db)
DATA_PATH=/app/data/config.db
