# Development mode (optional, default: false)
# Set to "true" to enable development mode with default JWT secret
DEV_MODE=false

# JWT secret key (optional)
# If unset, a random secret is auto-generated and persisted in SQLite on first run.
# Set this to pin the secret across deployments (e.g. when rotating containers).
# JWT_SECRET=your-secure-secret-key-here

# Server listen address (optional, default: localhost:9093)
# Must be 0.0.0.0:9093 in Docker so the container listens on all interfaces.
# docker-compose.yml sets this automatically — no need to set it here for Docker.
ADDR=localhost:9093

# SQLite database path (optional, default: /app/data/config.db)
DATA_PATH=/app/data/config.db
